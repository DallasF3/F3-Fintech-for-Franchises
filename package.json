{
  "name": "f3-fintech-for-franchises",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "npm run build --workspace=apps/backend && npm run build --workspace=apps/frontend && npm run build --workspace=packages/shared",
    "build:turbo": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
